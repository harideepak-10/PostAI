# OpenAI API Key (for image generation + caption generation)
OPENAI_API_KEY=your_openai_api_key_here

# LinkedIn API
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID

# Facebook / Instagram API (Facebook Graph API)
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# Instagram (connected via Facebook Graph API)
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# Server
PORT=3000
